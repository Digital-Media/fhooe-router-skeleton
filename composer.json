{
    "name": "fhooe/router-skeleton",
    "description": "An example application or skeleton for getting started with fhooe/router.",
    "license": "MIT",
    "type": "project",
    "keywords": [
        "routing",
        "example",
        "education"
    ],
    "authors": [
        {
            "name": "Wolfgang Hochleitner",
            "email": "wolfgang.hochleitner@fh-hagenberg.at",
            "role": "Developer"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../fhooe-router",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../fhooe-latte-extensions",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.5",
        "fhooe/latte-extensions": "^1.0",
        "fhooe/router": "^3.0",
        "latte/latte": "^3.0",
        "monolog/monolog": "^3.10"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "ergebnis/composer-normalize": "^2.45",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "": [
                "src/"
            ]
        }
    },
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse public views --memory-limit=-1 --level 9",
        "start": [
            "echo 'Web server launched on http://localhost:8888'",
            "php -S localhost:8888 -t public"
        ],
        "test": [
            "@cs-check",
            "@phpstan"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    }
}
